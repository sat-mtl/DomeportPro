                        "Fragment": "/*{\n  \"CREDIT\": \"ossia score\",\n  \"ISFVSN\": \"2\",\n  \"DESCRIPTION\": \"Copy the input texture without changes\",\n  \"CATEGORIES\": [\n    \"Utility\"\n  ],\n  \"INPUTS\": [ {\n      \"NAME\": \"inputImage\",\n      \"TYPE\": \"image\"\n    }\n  ]\n}*/\n\nvoid main() { gl_FragColor = IMG_THIS_PIXEL(inputImage); }",
