e","Label":"","Touched":true},"Duration":12400285870,"Height":300.0,"StartOffset":0,"LoopDuration":12400285870,"Pos":[-1516.916974684488,-1968.3861033441872],"Size":[198.609375,22.0],"Loops":false,"Script":"import Score 1.0\nScript {\n  ValueInlet { id: in1 }\n  ValueOutlet { id: out1 }\n  FloatSpinBox { \n    id: filtered_value\n    objectName: \"Filtered value\"\n    init: 0\n  }\n\n  property real prev_input: 0.0\n  \n  tick: function(token, state) {\n    \n    if (in1.value != filtered_value.value) {\n      out1.value = in1.value;\n    }    \n    else {\n      if (prev_input == filtered_value.value) {\n        // do nothing\n      }\n      else {\n        // It is a new zero -> Keep it\n        out1.value = in1.value; \n      }\n    }\n    if (in1.value != undefined) prev_input = in1.value;\n  }\n}\n","Inlets":[{"uuid":"769dd38a-bfb3-4dc6-b52a-b6abb7afe2a3","ObjectName":"Inlet","id":0,"Hidden":false},{"uuid":"10d62b0d-5bc9-4ac9-9540-9e8ac0c24947","ObjectName":"Inlet","id":1,"Hidden":true,"Custom":"Filtered value","Exposed":"filtered value","Value":{"Float":0.0},"Init":{"Float":0.0},"Domain":{"Float":{"Min":0.0,"Max":1.0}}}],"Outlets":[{"uuid":"cff96158-cc72-46d7-99dc-b6038171375b","ObjectName":"Outlet","id":0,"Hidden":false}]},{"uuid":"846a5de5-47f9-46c5-a898-013cb20951d0","ObjectName":"Javascript","id":190,"Metadata":{"ScriptingName":"keyboard_gamepad_converter","Comment":"","Color":"White","Label":"","Touched":true},"Duration":12400285870,"Height":300.0,"StartOffset":0,"LoopDuration":10584000000,"Pos":[-1875.479474684488,-1071.3861033441872],"Size":[194.515625,22.0],"Loops":false,"Script":"import Score\nimport QtQuick\n\nScript {\n  ValueInlet { id: keypress; objectName: \"Keycode press\" }\n  ValueInlet { id: keyrelease; objectName: \"Keycode release\"  }\n  \n  ValueOutlet { id: leftStickX;  objectName: \"Left Stick X (-1 Left, +1 Right)\" }\n  ValueOutlet { id: leftStickY;  objectName: \"Left Stick Y (-1 Up/Forward, +1 Down/Backward)\" }\n  ValueOutlet { id: rightStickX; objectName: \"Right Stick X (-1 Turn Left, +1 Turn Right)\" }\n  ValueOutlet { id: rightStickY; objectName: \"Right Stick Y (-1 Look Up, +1 Look Down)\" }\n  ValueOutlet { id: moveUp;   objectName: \"Move Up (0 to 1)\" }\n  ValueOutlet { id: moveDown; objectName: \"Move Down (0 to 1)\" }\n  \n  // Keycodes\n  readonly property int g_W_KEYCODE: 87 \n  readonly property int g_S_KEYCODE: 83 \n  readonly property int g_A_KEYCODE: 65 \n  readonly property int g_D_KEYCODE: 68 \n\n  readonly property int g_UP_KEYCODE: 16777235    \n  readonly property int g_DOWN_KEYCODE: 16777237  \n  readonly property int g_LEFT_KEYCODE: 16777234  \n  readonly property int g_RIGHT_KEYCODE: 16777236 \n\n  readonly property int g_LCTRL_KEYCODE: 16777249  \n  readonly property int g_LSHIFT_KEYCODE: 16777248 \n  \n  // Defines the \"strength\" of the stick push. \n  // Usually Gamepad sticks go from -1.0 to 1.0. \n  // If you want a slower speed, reduce this value.\n  readonly property real speed: 1.0 \n\n  property var pressed: new Set();\n\n  tick: function(token, state) {\n     // 1. Update the Set of pressed keys\n     for(const k of keypress.values) {\n       pressed.add(k.value);\n     }\n     for(const k of keyrelease.values) {\n       pressed.delete(k.value);\n     }\n\n     // 2. Initialize local variables to 0.0 for this frame\n     let lx = 0.0;\n     let ly = 0.0;\n     let rx = 0.0;\n     let ry = 0.0;\n     let up_val = 0.0;\n     let down_val = 0.0;\n\n     // 3. Check keys and modify local variables\n     // Note: I used 'speed' (1.0) here, assuming this connects to \n     // a Joystick node. If this drives position directly, change 'speed' to 0.03.\n     \n     if(pressed.has(g_W_KEYCODE)) ly -= speed;      // Forward\n     if(pressed.has(g_S_KEYCODE)) ly += speed;      // Backward\n     \n     if(pressed.has(g_A_KEYCODE)) lx -= speed;      // Left (usually negative on X)\n     if(pressed.has(g_D_KEYCODE)) lx += speed;      // Right (usually positive on X)\n\n     if(pressed.has(g_LSHIFT_KEYCODE)) up_val = speed; \n     if(pressed.has(g_LCTRL_KEYCODE)) down_val = speed; \n     \n     if(pressed.has(g_UP_KEYCODE)) ry -= speed;\n     if(pressed.has(g_DOWN_KEYCODE)) ry += speed;\n     \n     if(pressed.has(g_LEFT_KEYCODE)) rx -= speed;\n     if(pressed.has(g_RIGHT_KEYCODE)) rx += speed;\n\n     // 4. Assign to outlets (Resets to 0 if no keys are pressed)\n     leftStickX.value = lx;\n     leftStickY.value = ly;\n     rightStickX.value = rx;\n     rightStickY.value = ry;\n     moveUp.value = up_val;\n     moveDown.value = down_val;\n  }\n}","Inlets":[{"uuid":"769dd38a-bfb3-4dc6-b52a-b6abb7afe2a3","ObjectName":"Inlet","id":0,"Hidden":false,"Custom":"Keycode press","Exposed":"keycode press","Address":"Window:/key/press/code"},{"uuid":"769dd38a-bfb3-4dc6-b52a-b6abb7afe2a3","ObjectName":"Inlet","id":1,"Hidden":false,"Custom":"Keycode release","Exposed":"keycode release","Address":"Window:/key/release/code"}],"Outlets":[{"uuid":"cff96158-cc72-46d7-99dc-b6038171375b","ObjectName":"Outlet","id":0,"Hidden":false,"Custom":"Left Stick X (-1 Left, +1 Right)","Exposed":"left stick x (-1 left_ _1 right)"},{"uuid":"cff96158-cc72-46d7-99dc-b6038171375b","ObjectName":"Outlet","id":1,"Hidden":false,"Custom":"Left Stick Y (-1 Up/Forward, +1 Down/Backward)","Exposed":"left stick y (-1 up_forward_ _1 down_backward)"},{"uuid":"cff96158-cc72-46d7-99dc-b6038171375b","ObjectName":"Outlet","id":2,"Hidden":false,"Custom":"Right Stick X (-1 Turn Left, +1 Turn Right)","Exposed":"right stick x (-1 turn left_ _1 turn right)"},{"uuid":"cff96158-cc72-46d7-99dc-b6038171375b","ObjectName":"Outlet","id":3,"Hidden":false,"Custom":"Right Stick Y (-1 Look Up, +1 Look Down)","Exposed":"right stick y (-1 look up_ _1 look down)"},{"uuid":"cff96158-cc72-46d7-99dc-b6038171375b","ObjectName":"Outlet","id":4,"Hidden":false,"Custom":"Move Up (0 to 1)","Exposed":"move up (0 to 1)"},{"uuid":"cff96158-cc72-46d7-99dc-b6038171375b","ObjectName":"Outlet","id":5,"Hidden":false,"Custom":"Move Down (0 to 1)","Exposed":"move down (0 to 1)"}]},{"uuid":"846a5de5-47f9-46c5-a898-013cb20951d0","ObjectName":"Javascript","id":189,"Metadata":{"ScriptingName":"keyboard FPS Cam","Comment":"","Color":"White","Label":"","Touched":true},"Duration":12400285870,"Height":300.0,"StartOffset":0,"LoopDuration":10584000000,"Pos":[-1077.4794746844882,-1481.3861033441872],"Size":[120.390625,22.0],"Loops":false,"Script":"import Score\nimport QtQuick\n\n// Jean-Michael Celerier (modified by Edu Meneses)\n\n/**\n * From input keycodes, create a FPS camera movement, e.g.\n * gives the camera position and camera target (e.g. lookAt).\n * Controls are:\n * - WASD for position (QWERTY layout)\n * - ZQSD for position (AZERTY layout - original, see old keycodes)\n * - up / down / left / right for camera orientation\n * - left shift / left ctrl for going up / down\n */\nScript {\n  ValueInlet { id: keypress; objectName: \"Keycode press\" }\n  ValueInlet { id: keyrelease; objectName: \"Keycode release\"  }\n  ValueOutlet { id: position; objectName: \"Camera position\"  }\n  ValueOutlet { id: center; objectName: \"Camera target\" }\n\n  // Keycodes for QWERTY layout (WASD)\n  // Original AZERTY keycodes were: Z=90, Q=81. S and D are the same.\n  readonly property int g_W_KEYCODE: 87 // Qt::Key_W (was 90 for Z on AZERTY)\n  readonly property int g_S_KEYCODE: 83 // Qt::Key_S\n  readonly property int g_A_KEYCODE: 65 // Qt::Key_A (was 81 for Q on AZERTY)\n  readonly property int g_D_KEYCODE: 68 // Qt::Key_D\n\n  readonly property int g_UP_KEYCODE: 16777235    // Qt::Key_Up\n  readonly property int g_DOWN_KEYCODE: 16777237  // Qt::Key_Down\n  readonly property int g_LEFT_KEYCODE: 16777234  // Qt::Key_Left\n  readonly property int g_RIGHT_KEYCODE: 16777236 // Qt::Key_Right\n\n  readonly property int g_LCTRL_KEYCODE: 16777249  // Qt::Key_Control (used for Left Ctrl)\n  readonly property int g_LSHIFT_KEYCODE: 16777248 // Qt::Key_Shift (used for Left Shift)\n  \n  property real cur_x: 0\n  property real cur_y: 0\n  property real cur_z: 0\n  \n  property real cur_pitch: 0\n  property real cur_yaw: 0\n  \n  property var pressed: new Set();\n\n  tick: function(token, state) {\n     for(const k of keypress.values) {\n       const code = k.value;\n       pressed.add(code);\n     }\n     for(const k of keyrelease.values) {\n       const code = k.value;\n       pressed.delete(code);\n     }\n\n     let move_x = 0.0; // front-back\n     let move_y = 0.0; // up-down\n     let move_z = 0.0; // left-right\n\n     let move_pitch = 0.0; // up-down\n     let move_yaw = 0.0; // rotation\n\n     if(pressed.has(g_W_KEYCODE)) move_x += 0.03;      // Forward\n     if(pressed.has(g_S_KEYCODE)) move_x -= 0.03;      // Backward\n     if(pressed.has(g_LSHIFT_KEYCODE)) move_y += 0.03; // Up\n     if(pressed.has(g_LCTRL_KEYCODE)) move_y -= 0.03;  // Down\n     if(pressed.has(g_A_KEYCODE)) move_z += 0.03;      // Strafe Left\n     if(pressed.has(g_D_KEYCODE)) move_z -= 0.03;      // Strafe Right\n     \n     if(pressed.has(g_UP_KEYCODE)) move_pitch += 0.01;\n     if(pressed.has(g_DOWN_KEYCODE)) move_pitch -= 0.01;\n     if(pressed.has(g_LEFT_KEYCODE)) move_yaw += 0.01;\n     if(pressed.has(g_RIGHT_KEYCODE)) move_yaw -= 0.01;\n     \n     // 1. Update the rotation, e.g. where we look at.\n     //    Clamp it as there's a pole at 90 / -90°\n     cur_pitch = Math.min(Math.max(cur_pitch + move_pitch, -0.5 * 3.1415), 0.5 * 3.1415);\n     cur_yaw = cur_yaw + move_yaw;   \n     if(cur_yaw >= Math.PI)\n      cur_yaw = cur_yaw - 2. * Math.PI;\n     if(cur_yaw < -Math.PI)\n      cur_yaw = cur_yaw + 2. * Math.PI;\n     const cur_roll = 0.;\n\n     // 2. We want to move in the direction pointerd to by the camera on a straight plane\n     //    We compute the vector that goes from \"current position\" to \"looked at position\"\n     // 1. Forward direction vector from yaw and pitch\n     const look_dir_x = Math.cos(cur_pitch) * Math.sin(cur_yaw);\n     const look_dir_y = Math.sin(cur_pitch);\n     const look_dir_z = Math.cos(cur_pitch) * Math.cos(cur_yaw);\n\n     // 2. Update position using movement input\n     cur_x += move_x * Math.sin(cur_yaw) + move_z * Math.cos(cur_yaw);\n     cur_y += move_y;\n     cur_z += move_x * Math.cos(cur_yaw) - move_z * Math.sin(cur_yaw);\n\n     position.value = Qt.vector3d(cur_x, cur_y, cur_z);\n     center.value = Qt.vector3d(cur_x + look_dir_x, cur_y + look_dir_y, cur_z + look_dir_z);\n  }\n}","Inlets":[{"uuid":"769dd38a-bfb3-4dc6-b52a-b6abb7afe2a3","ObjectName":"Inlet","id":0,"Hidden":false,"Custom":"Keycode press","Exposed":"keycode press","Address":"Window:/key/press/code"},{"uuid":"769dd38a-bfb3-4dc6-b52a-b6abb7afe2a3","ObjectName":"Inlet","id":1,"Hidden":false,"Custom":"Keycode release","Exposed":"keycode release","Address":"Window:/key/release/code"}],"Outlets":[{"uuid":"cff96158-cc72-46d7-99dc-b6038171375b","ObjectName":"Outlet","id":0,"Hidden":false,"Custom":"Camera position","Exposed":"camera position"},{"uuid":"cff96158-cc72-46d7-99dc-b6038171375b","ObjectName":"Outlet","id":1,"Hidden":false,"Custom":"Camera target","Exposed":"camera target"}]},{"uuid":"846a5de5-47f9-46c5-a898-013cb20951d0","ObjectName":"Javascript","id":188,"Metadata":{"ScriptingName":"single-value_repetition_filter.1","Comment":"","Color":"White","Label":"","Touched":true},"Duration":12400285870,"Height":300.0,"StartOffset":0,"LoopDuration":12400285870,"Pos":[-1522.8857246844882,-1268.461103344187],"Size":[198.609375,22.0],"Loops":false,"Script":"import Score 1.0\nScript {\n  ValueInlet { id: in1 }\n  ValueOutlet { id: out1 }\n  FloatSpinBox { \n    id: filtered_value\n    objectName: \"Filtered value\"\n    init: 0\n  }\n\n  property real prev_input: 0.0\n  \n  tick: function(token, state) {\n    \n    if (in1.value != filtered_value.value) {\n      out1.value = in1.value;\n    }    \n    else {\n      if (prev_input == filtered_value.value) {\n        // do nothing\n      }\n      else {\n        // It is a new zero -> Keep it\n        out1.value = in1.value; \n      }\n    }\n    if (in1.value != undefined) prev_input = in1.value;\n  }\n}\n","Inlets":[{"uuid":"769dd38a-bfb3-4dc6-b52a-b6abb7afe2a3","ObjectName":"Inlet","id":0,"Hidden":false},{"uuid":"10d62b0d-5bc9-4ac9-9540-9e8ac0c24947","ObjectName":"Inlet","id":1,"Hidden":true,"Custom":"Filtered value","Exposed":"filtered value","Value":{"Float":0.0},"Init":{"Float":0.0},"Domain":{"Float":{"Min":0.0,"Max":1.0}}}],"Outlets":[{"uuid":"cff96158-cc72-46d7-99dc-b6038171375b","ObjectName":"Outlet","id":0,"Hidden":false}]},{"uuid":"846a5de5-47f9-46c5-a898-013cb20951d0","ObjectName":"Javascript","id":187,"Metadata":{"ScriptingName":"single-value_repetition_filter","Comment":"","Color":"White","Label":"","Touched":true},"Duration":12400285870,"Height":300.0,"StartOffset":0,"LoopDuration":12400285870,"Pos":[-1514.2274434344884,-2135.9804314691874],"Size":[189.828125,22.0],"Loops":false,"Script":"import Score 1.0\nScript {\n  ValueInlet { id: in1 }\n  ValueOutlet { id: out1 }\n  FloatSpinBox { \n    id: filtered_value\n    objectName: \"Filtered value\"\n    init: 0\n  }\n\n  property real prev_input: 0.0\n  \n  tick: function(token, state) {\n    \n    if (in1.value != filtered_value.value) {\n      out1.value = in1.value;\n    }    \n    else {\n      if (prev_input == filtered_value.value) {\n        // do nothing\n      }\n      else {\n        // It is a new zero -> Keep it\n        out1.value = in1.value; \n      }\n    }\n    if (in1.value != undefined) prev_input = in1.value;\n  }\n}\n","Inlets":[{"uuid":"769dd38a-bfb3-4dc6-b52a-b6abb7afe2a3","ObjectName":"Inlet","id":0,"Hidden":false},{"uuid":"10d62b0d-5bc9-4ac9-9540-9e8ac0c24947","ObjectName":"Inlet","id":1,"Hidden":true,"Custom":"Filtered value","Exposed":"filtered value","Value":{"Float":0.0},"Init":{"Float":0.0},"Domain":{"Float":{"Min":0.0,"Max":1.0}}}],"Outlets":[{"uuid":"cff96158-cc72-46d7-99dc-b6038171375b","ObjectName":"Outlet","id":0,"Hidden":false}]},{"uuid":"ae6e3c9f-40cf-493a