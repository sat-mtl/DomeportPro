bb7afe2a3","ObjectName":"Inlet","id":0,"Hidden":false},{"uuid":"10d62b0d-5bc9-4ac9-9540-9e8ac0c24947","ObjectName":"Inlet","id":1,"Hidden":true,"Custom":"Filtered value","Exposed":"filtered value","Value":{"Float":0.0},"Init":{"Float":0.0},"Domain":{"Float":{"Min":0.0,"Max":1.0}}}],"Outlets":[{"uuid":"cff96158-cc72-46d7-99dc-b6038171375b","ObjectName":"Outlet","id":0,"Hidden":false}]},{"uuid":"846a5de5-47f9-46c5-a898-013cb20951d0","ObjectName":"Javascript","id":206,"Metadata":{"ScriptingName":"single-value_repetition_filter.13","Comment":"","Color":"White","Label":"","Touched":true},"Duration":12400285870,"Height":300.0,"StartOffset":0,"LoopDuration":12400285870,"Pos":[-1514.0970881353005,-529.3272035587506],"Size":[205.984375,22.0],"Loops":false,"Script":"import Score 1.0\nScript {\n  ValueInlet { id: in1 }\n  ValueOutlet { id: out1 }\n  FloatSpinBox { \n    id: filtered_value\n    objectName: \"Filtered value\"\n    init: 0\n  }\n\n  property real prev_input: 0.0\n  \n  tick: function(token, state) {\n    \n    if (in1.value != filtered_value.value) {\n      out1.value = in1.value;\n    }    \n    else {\n      if (prev_input == filtered_value.value) {\n        // do nothing\n      }\n      else {\n        // It is a new zero -> Keep it\n        out1.value = in1.value; \n      }\n    }\n    if (in1.value != undefined) prev_input = in1.value;\n  }\n}\n","Inlets":[{"uuid":"769dd38a-bfb3-4dc6-b52a-b6abb7afe2a3","ObjectName":"Inlet","id":0,"Hidden":false},{"uuid":"10d62b0d-5bc9-4ac9-9540-9e8ac0c24947","ObjectName":"Inlet","id":1,"Hidden":true,"Custom":"Filtered value","Exposed":"filtered value","Value":{"Float":0.0},"Init":{"Float":0.0},"Domain":{"Float":{"Min":0.0,"Max":1.0}}}],"Outlets":[{"uuid":"cff96158-cc72-46d7-99dc-b6038171375b","ObjectName":"Outlet","id":0,"Hidden":false}]},{"uuid":"3f4a41f2-fa39-420f-ab0f-0af6b8409edb","ObjectName":"Display","id":207,"Metadata":{"ScriptingName":"Value display","Comment":"","Color":"White","Label":"","Touched":true},"Duration":12400285870,"Height":300.0,"StartOffset":0,"LoopDuration":12400285870,"Pos":[-1713.8392756353005,-874.3272035587506],"Size":[200.0,100.0],"Loops":false,"Inlets":[{"uuid":"9a13fb32-269a-47bf-99a9-930188c1f19c","ObjectName":"Inlet","id":0,"Hidden":true,"Custom":"in","Exposed":"in","Value":{},"Init":{},"Domain":{}},{"uuid":"238399a0-7e81-47e3-896f-08e8856e2973","ObjectName":"Inlet","id":1,"Hidden":true,"Custom":"Log","Exposed":"log","Value":{"Int":1},"Init":{"Int":1},"Domain":{"Int":{"Min":1,"Max":100}}}],"Outlets":[]},{"uuid":"3f4a41f2-fa39-420f-ab0f-0af6b8409edb","ObjectName":"Display","id":208,"Metadata":{"ScriptingName":"Value display.209","Comment":"","Color":"White","Label":"","Touched":true},"Duration":12400285870,"Height":300.0,"StartOffset":0,"LoopDuration":12400285870,"Pos":[40.0,40.0],"Size":[200.0,100.0],"Loops":false,"Inlets":[{"uuid":"9a13fb32-269a-47bf-99a9-930188c1f19c","ObjectName":"Inlet","id":0,"Hidden":true,"Custom":"in","Exposed":"in","Value":{},"Init":{},"Domain":{}},{"uuid":"238399a0-7e81-47e3-896f-08e8856e2973","ObjectName":"Inlet","id":1,"Hidden":true,"Custom":"Log","Exposed":"log","Value":{"Int":1},"Init":{"Int":1},"Domain":{"Int":{"Min":1,"Max":100}}}],"Outlets":[]},{"uuid":"3f4a41f2-fa39-420f-ab0f-0af6b8409edb","ObjectName":"Display","id":209,"Metadata":{"ScriptingName":"Value display.211","Comment":"","Color":"White","Label":"","Touched":true},"Duration":12400285870,"Height":300.0,"StartOffset":0,"LoopDuration":12400285870,"Pos":[-1832.1049006353005,-556.3272035587506],"Size":[200.0,100.0],"Loops":false,"Inlets":[{"uuid":"9a13fb32-269a-47bf-99a9-930188c1f19c","ObjectName":"Inlet","id":0,"Hidden":true,"Custom":"in","Exposed":"in","Value":{},"Init":{},"Domain":{}},{"uuid":"238399a0-7e81-47e3-896f-08e8856e2973","ObjectName":"Inlet","id":1,"Hidden":true,"Custom":"Log","Exposed":"log","Value":{"Int":1},"Init":{"Int":1},"Domain":{"Int":{"Min":1,"Max":100}}}],"Outlets":[]},{"uuid":"9906e563-ddeb-4ecd-908c-952baee2a0a5","ObjectName":"SignalDisplay","id":210,"Metadata":{"ScriptingName":"Signal display","Comment":"","Color":"White","Label":"","Touched":true},"Duration":12400285870,"Height":300.0,"StartOffset":0,"LoopDuration":12400285870,"Pos":[-1745.1128683426405,-738.6406434901814],"Size":[200.0,100.0],"Loops":true,"Inlets":[{"uuid":"9a13fb32-269a-47bf-99a9-930188c1f19c","ObjectName":"Inlet","id":0,"Hidden":true,"Custom":"in","Exposed":"in","Value":{},"Init":{},"Domain":{}}],"Outlets":[{"uuid":"3620ea94-5991-41cf-89b3-11f842cc39d0","ObjectName":"Outlet","id":0,"Hidden":true,"Custom":"out","Exposed":"out","Value":{"Tuple":[{"Float":0.7599992752075195},{"Float":0.0}]},"Domain":{}}]},{"uuid":"846a5de5-47f9-46c5-a898-013cb20951d0","ObjectName":"Javascript","id":204,"Metadata":{"ScriptingName":"Mouse_input","Comment":"","Color":"White","Label":"","Touched":true},"Duration":12400285870,"Height":300.0,"StartOffset":0,"LoopDuration":12400285870,"Pos":[-2082.1049006353005,-729.3272035587506],"Size":[86.25,22.0],"Loops":false,"Script":"import Score 1.0\n\nScript {\n  // --- INPUTS ---\n  // Connect your mouse position here (Array [x, y])\n  // Supports both Normalized (0-1) and Pixel coordinates.\n  ValueInlet { \n    id: mousePos\n    objectName: \"Mouse position (x, y)\"\n\n  } \n\n  // Connect your Mouse Left Click here\n  // Expects 1 (or > 0) for pressed, 0 for released.\n  ValueInlet { \n    id: clickTrigger \n    objectName: \"Click trigger\"\n} \n\n  // --- OUTPUTS ---\n  // Outputs Yaw and Pitch (from -1 to 1)\n  ValueOutlet { \n    id: outCamera_X\n    objectName: \"Camera X\"\n  } \n  \n  ValueOutlet { \n    id: outCamera_Y\n    objectName: \"Camera Y\"\n  } \n\n  // --- CONTROLS ---\n  // Adjusts how fast the camera turns relative to mouse speed\n  FloatSlider { \n    id: sensitivity\n    min: 0.1\n    max: 50.0\n    init: 5.0\n    objectName: \"Sensitivity\"\n  }\n  \n  // 0 = No smoothing (raw), 0.95 = Very heavy/slow inertia\n  FloatSlider { \n    id: smoothing\n    min: 0.0\n    max: 0.99\n    init: 0.5\n    objectName: \"Smoothing (Inertia)\"\n  }\n  \n  // Standard camera control often requires inverting Y\n  Toggle { \n    id: invertY\n    //value: false\n    objectName: \"Invert Y Axis\"\n  }\n\n  // --- INTERNAL STATE ---\n  property var lastPos: [0, 0];\n  property var currentVel: [0, 0];\n  property bool initialized: false;\n\n  tick: function(token, state) {\n    // 1. Safety Checks: Ensure we have valid inputs\n    if (typeof mousePos.value === 'undefined' || mousePos.value.length < 2) {\n      return;\n    }\n    \n    var mx = mousePos.value[0];\n    var my = mousePos.value[1];\n    var isClicked = (typeof clickTrigger.value !== 'undefined' && clickTrigger.value > 0.5);\n\n    // Initialize lastPos on the very first run to prevent a \"jump\" start\n    if (!initialized) {\n      lastPos = [mx, my];\n      initialized = true;\n      return;\n    }\n\n    // 2. Calculate Raw Delta (Change in position)\n    var dx = mx - lastPos[0];\n    var dy = my - lastPos[1];\n\n    // Always update lastPos, so we don't jump when we eventually click\n    lastPos = [mx, my];\n\n    // 3. Logic: If not clicked, we send 0 velocity and reset inertia\n    if (!isClicked) {\n      currentVel = [0, 0];\n      outCamera_X.value = 0;\n      outCamera_Y.value = 0;\n      return;\n    }\n\n    // 4. Scaling\n    // We multiply by a constant factor because Normalized coordinates (0.0 - 1.0)\n    // produce tiny deltas (e.g., 0.001). This boosts them up to usable ranges.\n    var speedMult = 100.0; \n    var targetX = dx * sensitivity.value * speedMult;\n    var targetY = dy * sensitivity.value * speedMult;\n\n    if (invertY.value) targetY = -targetY;\n\n    // 5. Smoothing (Exponential Moving Average)\n    // This creates the \"fluid\" feel.\n    var alpha = 1.0 - smoothing.value;\n    \n    // Calculate new smoothed velocity\n    var smoothX = currentVel[0] + alpha * (targetX - currentVel[0]);\n    var smoothY = currentVel[1] + alpha * (targetY - currentVel[1]);\n    \n    // Store for next frame\n    currentVel = [smoothX, smoothY];\n\n    // 6. Clamping\n    // Ensure we strictly adhere to the -1 to 1 requirement\n    var finalX = Math.max(-1, Math.min(1, smoothX));\n    var finalY = Math.max(-1, Math.min(1, smoothY));\n\n    // 7. Output\n    outCamera_X.value = finalX;\n    outCamera_Y.value = finalY;\n  }\n}","Inlets":[{"uuid":"769dd38a-bfb3-4dc6-b52a-b6abb7afe2a3","ObjectName":"Inlet","id":0,"Hidden":false,"Custom":"Mouse position (x, y)","Exposed":"mouse position (x_ y)","Address":"Window:/cursor/scaled"},{"uuid":"769dd38a-bfb3-4dc6-b52a-b6abb7afe2a3","ObjectName":"Inlet","id":1,"Hidden":false,"Custom":"Click trigger","Exposed":"click trigger","Address":"ELAN06FA_00 04F3_327E Touchpad:/event/key/BTN_LEFT"},{"uuid":"af2b4fc3-aecb-4c15-a5aa-1c573a239925","ObjectName":"Inlet","id":2,"Hidden":true,"Custom":"Sensitivity","Exposed":"sensitivity","Value":{"Float":8.410040855407715},"Init":{"Float":5.0},"Domain":{"Float":{"Min":0.10000000149011612,"Max":50.0}}},{"uuid":"af2b4fc3-aecb-4c15-a5aa-1c573a239925","ObjectName":"Inlet","id":3,"Hidden":true,"Custom":"Smoothing (Inertia)","Exposed":"smoothing (inertia)","Value":{"Float":0.32986852526664734},"Init":{"Float":0.5},"Domain":{"Float":{"Min":0.0,"Max":0.9900000095367432}}},{"uuid":"fb27e4cb-ea7f-41e2-ad92-2354498c1b6b","ObjectName":"Inlet","id":4,"Hidden":true,"Custom":"Invert Y Axis","Exposed":"invert y axis","Value":{"Bool":false},"Init":{"Bool":false},"Domain":{"Bool":null}}],"Outlets":[{"uuid":"cff96158-cc72-46d7-99dc-b6038171375b","ObjectName":"Outlet","id":0,"Hidden":false,"Custom":"Camera X","Exposed":"camera x"},{"uuid":"cff96158-cc72-46d7-99dc-b6038171375b","ObjectName":"Outlet","id":1,"Hidden":false,"Custom":"Camera Y","Exposed":"camera y"}]}],"SmallViewRack":[{"Processes":[127,128,140,141,142,179,180,181,182,183,184,185,186,187,188,189,190,191,192,193,194,195,196,197,198,199,200,201,202,203,204,205,206,207,208,209],"Process":null,"Height":200.0,"Nodal":true},{"Processes":[210],