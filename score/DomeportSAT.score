Int":1}],["Fill",{"Int":2}],["Stretch",{"Int":3}]]}],"Outlets":[{"uuid":"f1c71046-b754-49a5-8e66-d01374773dfc","ObjectName":"Outlet","id":0,"Hidden":false,"Custom":"Texture Out","Exposed":"texture out"}]},{"uuid":"9ce44e4b-eeb6-4042-bb7f-9d0b28190daf","ObjectName":"gfxProcess","id":201,"Metadata":{"ScriptingName":"Model Display floor","Comment":"","Color":"White","Label":"","Touched":true},"Duration":12400285870,"Height":300.0,"StartOffset":0,"LoopDuration":10584000000,"Pos":[157.00896281551172,-1455.4598836148202],"Size":[128.984375,22.0],"Loops":false,"Inlets":[{"uuid":"5ac86198-2d03-4830-9e41-a6d529922d29","ObjectName":"Inlet","id":0,"Hidden":false,"Format":0,"Filter":2,"AddressMode":1},{"uuid":"f2ab26ea-415d-45a2-bfbc-2968c7c92a33","ObjectName":"Inlet","id":1,"Hidden":false},{"uuid":"377e8205-b442-4d54-8832-3761def522b2","ObjectName":"Inlet","id":2,"Hidden":true,"Custom":"Position","Exposed":"position","Value":{"Vec3f":[-0.9401659369468689,-0.9745359420776367,-0.9894371032714844]},"Init":{"Vec3f":[-1.0,-1.0,-1.0]},"Domain":{"Vec3f":{"Min":[-10000.0,-10000.0,-10000.0],"Max":[10000.0,10000.0,10000.0],"Values":[[],[],[]]}}},{"uuid":"377e8205-b442-4d54-8832-3761def522b2","ObjectName":"Inlet","id":3,"Hidden":true,"Custom":"Center","Exposed":"center","Value":{"Vec3f":[-0.960616409778595,0.19543378055095673,-0.4726027250289917]},"Init":{"Vec3f":[0.0,0.0,0.0]},"Domain":{"Vec3f":{"Min":[-10000.0,-10000.0,-10000.0],"Max":[10000.0,10000.0,10000.0],"Values":[[],[],[]]}}},{"uuid":"af2b4fc3-aecb-4c15-a5aa-1c573a239925","ObjectName":"Inlet","id":4,"Hidden":true,"Custom":"FOV","Exposed":"fov","Value":{"Float":90.0},"Init":{"Float":90.0},"Domain":{"Float":{"Min":0.009999999776482582,"Max":359.9989929199219}}},{"uuid":"af2b4fc3-aecb-4c15-a5aa-1c573a239925","ObjectName":"Inlet","id":5,"Hidden":true,"Custom":"Near","Exposed":"near","Value":{"Float":0.0010000000474974513},"Init":{"Float":0.0010000000474974513},"Domain":{"Float":{"Min":0.0010000000474974513,"Max":1000.0}}},{"uuid":"a