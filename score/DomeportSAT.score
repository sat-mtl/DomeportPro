tom":"Beta (1e only)","Exposed":"beta (1e only)","Value":{"Float":1.0},"Init":{"Float":1.0},"Domain":{"Float":{"Min":0.0010000000474974513,"Max":10.0}}},{"uuid":"fb27e4cb-ea7f-41e2-ad92-2354498c1b6b","ObjectName":"Inlet","id":6,"Hidden":true,"Custom":"Continuous","Exposed":"continuous","Value":{"Bool":true},"Init":{"Bool":false},"Domain":{"Bool":null}}],"Outlets":[{"uuid":"cff96158-cc72-46d7-99dc-b6038171375b","ObjectName":"Outlet","id":0,"Hidden":false,"Custom":"out","Exposed":"out"}]},{"uuid":"bf603921-5a48-4aa5-9bc1-48a762be6467","ObjectName":"ValueFilter","id":141,"Metadata":{"ScriptingName":"Smooth pos","Comment":"","Color":"White","Label":"","Touched":true},"Duration":12400285870,"Height":300.0,"StartOffset":0,"LoopDuration":10584000000,"Pos":[-757.0987740682668,-1677.4820095315856],"Size":[79.109375,22.0],"Loops":false,"Inlets":[{"uuid":"769dd38a-bfb3-4dc6-b52a-b6abb7afe2a3","ObjectName":"Inlet","id":0,"Hidden":false,"Custom":"in","Exposed":"in"},{"uuid":"8b1d76c4-3838-4ac0-9b9c-c12bc5db8e8a","ObjectName":"Inlet","id":1,"Hidden":true,"Custom":"Type","Exposed":"type","Value":{"String":"OneEuro"},"Init":{"String":"OneEuro"},"Domain":{"String":{"Values":["OneEuro","LowPass","Average","Median"]}},"Values":["OneEuro","LowPass","Average","Median"],"Pixmaps":[]},{"uuid":"82427d27-084a-4ab6-9c4e-db83929a1200","ObjectName":"Inlet","id":2,"Hidden":true,"Custom":"Amount","Exposed":"amount","Value":{"Float":1.0},"Init":{"Float":0.10000000149011612},"Domain":{"Float":{"Min":0.0,"Max":1.0}}},{"uuid":"5554eb67-bcc8-45ab-8ec2-37a3f191aa64","ObjectName":"Inlet","id":3,"Hidden":true,"Custom":"Freq (1e/LP)","Exposed":"freq (1e_lp)","Value":{"Float":120.0},"Init":{"Float":120.0},"Domain":{"Float":{"Min":0.0010000000474974513,"Max":300.0}}},{"uuid":"5554eb67-bcc8-45ab-8ec2-37a3f191aa64","ObjectName":"Inlet","id":4,"Hidden":true,"Custom":"Cutoff (1e/LP)","Exposed":"cutoff (1e_lp)","Value":{"Float":1.0},"Init":{"Float":1.0},"Domain":{"Float":{"Min":0.0010000000474974513,"Max":10.0}}},{"uuid":"af2b4fc3-aecb-4c15-a5aa-1c573a239925","ObjectName":"Inlet","id":5,"Hidden":true,"Custom":"Beta (1e only)","Exposed":"beta (1e only)","Value":{"Float":1.0},"Init":{"Float":1.0},"Domain":{"Float":{"Min":0.0010000000474974513,"Max":10.0}}},{"uuid":"fb27e4cb-ea7f-41e2-ad92-2354498c1b6b","ObjectName":"Inlet","id":6,"Hidden":true,"Custom":"Continuous","Exposed":"continuous","Value":{"Bool":true},"Init":{"Bool":false},"Domain":{"Bool":null}}],"Outlets":[{"uuid":"cff96158-cc72-46d7-99dc-b6038171375b","ObjectName":"Outlet","id":0,"Hidden":false,"Custom":"out","Exposed":"out"}]},{"uuid":"846a5de5-47f9-46c5-a898-013cb20951d0","ObjectName":"Javascript","id":140,"Metadata":{"ScriptingName":"FPS Cam","Comment":"","Color":"White","Label":"","Touched":true},"Duration":12400285870,"Height":300.0,"StartOffset":0,"LoopDuration":10584000000,"Pos":[-1175.9026408364762,-1640.302432550283],"Size":[75.0,22.0],"Loops":false,"Script":"import Score // Required by ossia score environment\nimport QtQuick // Required by ossia score environment\n\n// Original script by Jean-Michael Celerier\n// Modified for analog stick input by Edu Meneses & AI Assistant\n\n/**\n * Creates FPS (First-Person Shooter) style camera movement based on analog stick and trigger inputs.\n * This script calculates the camera's 3D position and target point (lookAt).\n *\n * Controls:\n * - Left Stick X: Strafe left/right\n * - Left Stick Y: Move forward/backward (Y-axis inverted: -1 up/forward, +1 down/backward)\n * - Right Stick X: Turn left/right (yaw)\n * - Right Stick Y: Look up/down (pitch) (Y-axis inverted: -1 up, +1 down)\n * - Move Up Input: Ascend vertically (e.g., Right Trigger)\n * - Move Down Input: Descend vertically (e.g., Left Trigger)\n *\n * The script assumes analog stick inputs are continuous values ranging from -1.0 to 1.0,\n * and up/down movement inputs range from 0 to 1.0.\n */\nScript {\n  // === INPUTS ===\n  // Analog stick inputs, expected to provide values in the range -1.0 to 1.0.\n  ValueInlet { id: leftStickX;  objectName: \"Left Stick X (-1 Left, +1 Right)\" }\n  ValueInlet { id: leftStickY;  objectName: \"Left Stick Y (-1 Up/Forward, +1 Down/Backward)\" }\n  ValueInlet { id: rightStickX; objectName: \"Right Stick X (-1 Turn Left, +1 Turn Right)\" }\n  ValueInlet { id: rightStickY; objectName: \"Right Stick Y (-1 Look Up, +1 Look Down)\" }\n  \n  // Vertical movement inputs, expected to provide values from 0 to 1.\n  ValueInlet { id: moveUpInput;   objectName: \"Move Up (0 to 1)\" }\n  ValueInlet { id: moveDownInput; objectName: \"Move Down (0 to 1)\" }\n\n  // === OUTPUTS ===\n  ValueOutlet { id: position; objectName: \"Camera Position (vec3)\" }\n  ValueOutlet { id: center; objectName: \"Camera Target (vec3)\" }\n\n  // === CAMERA STATE PROPERTIES ===\n  property real cur_x: 0.0     // Camera position on X-axis\n  property real cur_y: 0.0     // Camera position on Y-axis\n  property real cur_z: 0.0     // Camera position on Z-axis\n  \n  property real cur_pitch: 0.0 // Camera rotation around its local X-axis (looking up/down)\n  property real cur_yaw: 0.0   // Camera rotation around the world Y-axis (turning left/right)\n\n  // === INPUT STATE PERSISTENCE ===\n  // Store the last known state of all inputs to ensure continuous movement\n  // even if the host environment only sends updates on value change.\n  property real last_ls_x_input: 0.0;\n  property real last_ls_y_input: 0.0;\n  property real last_rs_x_input: 0.0;\n  property real last_rs_y_input: 0.0;\n  property real last_move_up_input: 0.0;\n  property real last_move_down_input: 0.0;\n\n  // === SENSITIVITY SETTINGS ===\n  readonly property real movement_speed: 0.05; // Affects forward/backward, strafe, and up/down speed\n  readonly property real rotation_speed: 0.03; // Affects look up/down and turn left/right speed\n\n  /**\n   * Called repeatedly by ossia score to update camera state.\n   */\n  tick: function(token, state) {\n    // 1. Read all input values, using the last known value if the current one is undefined.\n    //    This ensures continuous movement when a stick or trigger is held steady.\n    if (leftStickX.value !== undefined)    last_ls_x_input = Number(leftStickX.value);\n    if (leftStickY.value !== undefined)    last_ls_y_input = Number(leftStickY.value);\n    if (rightStickX.value !== undefined)   last_rs_x_input = Number(rightStickX.value);\n    if (rightStickY.value !== undefined)   last_rs_y_input = Number(rightStickY.value);\n    if (moveUpInput.value !== undefined)   last_move_up_input = Number(moveUpInput.value);\n    if (moveDownInput.value !== undefined) last_move_down_input = Number(moveDownInput.value);\n\n    // Use the persisted input values for all calculations this tick.\n    const current_ls_x = last_ls_x_input;\n    const current_ls_y = last_ls_y_input;\n    const current_rs_x = last_rs_x_input;\n    const current_rs_y = last_rs_y_input;\n    const current_move_up = last_move_up_input;\n    const current_move_down = last_move_down_input;\n\n    // 2. Calculate movement components.\n    let move_fwd_back = -current_ls_y * movement_speed;      // Y-axis inverted: negative for forward.\n    let strafe_val = -current_ls_x * movement_speed;         // Positive X for right, formula needs negative for right strafe.\n    let move_y = (current_move_up - current_move_down) * movement_speed; // Vertical movement.\n\n    // 3. Calculate rotational changes.\n    let delta_pitch = -current_rs_y * rotation_speed;      // Y-axis inverted: negative for look up.\n    let delta_yaw = -current_rs_x * rotation_speed;          // Positive X for turn right (negative yaw change).\n     \n    // 4. Update camera orientation (pitch and yaw).\n    cur_pitch += delta_pitch;\n    cur_yaw += delta_yaw;   \n    \n    // Clamp pitch to prevent looking straight up/down or flipping.\n    const pitch_limit = (0.5 * Math.PI) - 0.001; // Approx. +/- 89.94 degrees\n    cur_pitch = Math.max(-pitch_limit, Math.min(cur_pitch, pitch_limit));\n     \n    // Normalize yaw to keep it within [-PI, PI).\n    if (cur_yaw >= Math.PI) cur_yaw -= 2.0 * Math.PI;\n    if (cur_yaw < -Math.PI) cur_yaw += 2.0 * Math.PI;\n\n    // 5. Pre-calculate sine and cosine of the updated yaw for position calculation.\n    const sin_yaw = Math.sin(cur_yaw);\n    const cos_yaw = Math.cos(cur_yaw);\n\n    // 6. Update camera position (cur_x, cur_y, cur_z).\n    cur_x += move_fwd_back * sin_yaw + strafe_val * cos_yaw;\n    cur_y += move_y; // Apply vertical movement directly to the Y-axis.\n    cur_z += move_fwd_back * cos_yaw - strafe_val * sin_yaw;\n\n    // 7. Calculate the camera's target point (\"lookAt\" point).\n    const look_dir_x = Math.cos(cur_pitch) * sin_yaw;\n    const look_dir_y = Math.sin(cur_pitch);\n    const look_dir_z = Math.cos(cur_pitch) * cos_yaw;\n\n    // 8. Set the output values.\n    position.value = Qt.vector3d(cur_x, cur_y, cur_z);\n    center.value = Qt.vector3d(cur_x + look_dir_x, cur_y + look_dir_y, cur_z + look_dir_z);\n  }\n}\n","Inlets":[{"uuid":"769dd38a-bfb3-4dc6-b52a-b6abb7afe2a3","ObjectName":"Inlet","id":0,"Hidden":false,"Custom":"Left Stick X (-1 Left, +1 Right)","Exposed":"left stick x (-1 left_ _1 right)"},{"uuid":"769dd38a-bfb3-4dc6-b52a-b6abb7afe2a3","ObjectName":"Inlet","id":1,"Hidden":false,"Custom":"Left Stick Y (-1 Up/Forward, +1 Down/Backward)","Exposed":"left stick y (-1 up_forward_ _1 down_backward)"},{"uuid":"769dd38a-bfb3-4dc6-b52a-b6abb7afe2a3","ObjectName":"Inlet","id":2,"Hidden":false,"Custom":"Right Stick X (-1 Turn Left, +1 Turn Right)","Exposed":"right stick x (-1 turn left_ _1 turn right)"},{"uuid":"769dd38a-bfb3-4dc6-b52a-b6abb7afe2a3","ObjectName":"Inlet","id":3,"Hidden":false,"Custom":"Right Stick Y (-1 Look Up, +1 Look Down)","Exposed":"right stick y (-1 look up_ _1 look down)"},{"uuid":"769dd38a-bfb3-4dc6-b52a-b6abb7afe2a3","ObjectName":"Inlet","id":4,"Hidden":false,"Custom":"Move Up (0 to 1)","Exposed":"move up (0 to 1)"},{"uuid":"769dd38a-bfb3-4dc6-b52a-b6abb7afe2a3","ObjectName":"Inlet","id":5,"Hidden":false,"Custom":"Move Down (0 to 1)","Exposed":"move down (0 to 1)"}],"Outlets":[{"uuid":"cff96158-cc72-46d7-99dc-b6038171375b","ObjectName":"Outlet","id":0,"Hidden":false,"Custom":"Camera Position (vec3)","Exposed":"camera position (vec3)"},{"uuid":"cff96158-cc72-46d7-99dc-b6038171375b","ObjectName":"Outlet","id":1,"Hidden":false,"Custom":"Camera Target (vec3)","Exposed":"camera target (vec3)"}]},{"uuid":"74ca45ff-92c9-44a0-8f1a-754dea05ee1b","ObjectName":"gfxProcess","id":185,"Metadata":{"ScriptingName":"equirectangular_to_domemaster","Comment":"","Color":"White","Label":"","Touched":true},"Duration":12400285870,"Height":300.0,"StartOffset":0,"LoopDuration":12400285870,"Pos":[-611.1179121844884,-2075.0908213171306],"Size":[210.09375,22.0],"Loops":false,"Vertex":"","Fragment":"/*{\n    \"DESCRIPTION\": \"Generates a Domemaster output by projecting a rotated equirectangular image. Rotations, output FOV, and horizontal flip are controllable.\",\n    \"CREDIT\": \"Edu Meneses + AI Assistant (Gemini)\",\n    \"CATEGORIES\": [\n        \"GENERATOR\",\n        \"3D\",\n        \"DOME\",\n        \"PANORAMIC\"\n    ],\n    \"INPUTS\": [\n        { \"NAME\": \"equirectangularImage\", \"TYPE\": \"image\", \"LABEL\": \"Equirectangular Input\" },\n        {\n\t      \"NAME\" :\"XYZrotate\",\n\t      \"TYPE\" : \"point3D\",\n\t      \"DEFAULT\" : [0.5, 0.5, 0.5],\n\t      \"MAX\" : [1.0, 1.0, 1.0],\n\t      \"MIN\" : [0.0, 0.0, 0.0]\n\t    },\n        {\n            \"NAME\": \"domemaster_output_fov_degrees\",\n            \"LABEL\": \"Domemaster Output FOV (degrees)\",\n            \"TYPE\": \"float\",\n            \"DEFAULT\": 180.0,\n            \"MIN\": 1.0,\n            \"MAX\": 360.0\n        },\n        {\n            \"NAME\": \"flipHorizontal\",\n            \"LABEL\": \"Flip Horizontally (Ext. Surface)\",\n            \"TYPE\": \"bool\",\n            \"DEFAULT\": false\n        }\n    ]\n}*/\n\n#define M_PI 3.14159265359\n\n// Uniforms are implicitly declared from INPUTS\n// (flipHorizontal is now also an implicit uniform)\n\nmat3 makeRotationMatrix(vec3 a) // a = (yaw, pitch, roll)\n{\n    // ... (makeRotationMatrix function remains unchanged) ...\n    float cos_ax = cos(a.x); float sin_ax = sin(a.x);\n    float cos_ay = cos(a.y); float sin_ay = sin(a.y);\n    float cos_az = cos(a.z); float sin_az = sin(a.z);\n\n    mat3 my = mat3(cos(a.x), 0, sin(a.x),  0, 1, 0,  -sin(a.x), 0, cos(a.x)); // Yaw\n    mat3 mx = mat3(1, 0, 0,  0, cos(a.y), -sin(a.y),  0, sin(a.y), cos(a.y)); // Pitch\n    mat3 mz = mat3(cos(a.z), -sin(a.z), 0,  sin(a.z), cos(a.z), 0,  0,0,1);    // Roll\n\n    return my * mx * mz;\n}\n\n\nvoid main()\n{\n    vec2 p_norm_screen = vv_FragNormCoord; // Normalized screen coords [0,1]\n    vec2 p_centered = (p_norm_screen - 0.5) * 2.0; // Centered screen coords [-1,1]\n\n    // ADDED: Apply horizontal flip if toggled\n    if (flipHorizontal) {\n        p_centered.x = -p_centered.x;\n    }\n\n    float screen_aspect = RENDERSIZE.x / RENDERSIZE.y;\n    if (screen_aspect > 1.0) { // Landscape or square\n        p_centered.x *= screen_aspect;\n    } else { // Portrait\n        p_centered.y /= screen_aspect;\n    }\n\n    float dist_from_center = length(p_centered);\n\n    if (dist_from_center > 1.0) {\n        gl_FragColor = vec4(0.0, 0.0, 0.0, 0.0);\n        return;\n    }\n\n    float fisheye_half_fov_rad = (domemaster_output_fov_degrees / 2.0) * (M_PI / 180.0);\n    float ray_polar_angle_view = dist_from_center * fisheye_half_fov_rad;\n    float ray_azimuth_angle_view = atan(p_centered.y, p_centered.x);\n\n    vec3 ray_dir_view;\n    ray_dir_view.x = sin(ray_polar_angle_view) * cos(ray_azimuth_angle_view);\n    ray_dir_view.y = sin(ray_polar_angle_view) * sin(ray_azimuth_angle_view);\n    ray_dir_view.z = cos(ray_polar_angle_view);\n\n    float roll_angle  = (XYZrotate.z - 0.5) * 2.0 * M_PI;\n    float yaw_angle   = XYZrotate.x * 2.0 * M_PI;\n    float pitch_angle = XYZrotate.y * 2.0 * M_PI;\n\n    vec3 rotation_euler_angles = vec3(yaw_angle, pitch_angle, roll_angle);\n    mat3 camera_to_world_rotation_matrix = makeRotationMatrix(rotation_euler_angles);\n\n    vec3 ray_dir_world = camera_to_world_rotation_matrix * ray_dir_view;\n    vec3 norm_ray_dir_world = normalize(ray_dir_world);\n\n    float longitude = atan(norm_ray_dir_world.x, norm_ray_dir_world.z);\n    float latitude  = asin(norm_ray_dir_world.y);\n\n    float u = longitude / (2.0 * M_PI) + 0.5;\n    float v = 0.5 - latitude / M_PI;\n\n    vec2 equirect_uv = vec2(u, v);\n    vec4 sampled_color = texture(equirectangularImage, equirect_uv);\n    gl_FragColor = sampled_color;\n}","Inlets":[{"uuid":"5ac86198-2d03-4830-9e41-a6d529922d29","ObjectName":"Inlet","id":0,"Hidden":false,"Custom":"equirectangularImage","Exposed":"equirectangularimage","Format":0,"Filter":2,"AddressMode":1},{"uuid":"377e8205-b442-4d54-8832-3761def522b2","ObjectName":"Inlet","id":1,"Hidden":true,"Custom":"XYZrotate","Exposed":"xyzrotate","Value":{"Vec3f":[0.5,0.75,0.5]},"Init":{"Vec3f":[0.5,0.5,0.5]},"Domain":{"Vec3f":{"Min":[0.0,0.0,0.0],"Max":[1.0,1.0,1.0],"Values":[[],[],[]]}}},{"uuid":"af2b4fc3-aecb-4c15-a5aa-1c573a239925","ObjectName":"Inlet","id":2,"Hidden":true,"Custom":"domemaster_output_fov_degrees","Exposed":"domemaster_output_fov_degrees","Value":{"Float":210.0},"Init":{"Float":180.0},"Domain":{"Float":{"Min":1.0,"Max":360.0}}},{"uuid":"fb27e4cb-ea7f-41e2-ad92-2354498c1b6b","ObjectName":"Inlet","id":3,"Hidden":true,"Custom":"flipHorizontal","Exposed":"fliphorizontal","Value":{"Bool":false},"Init":{"Bool":false},"Domain":{"Bool":null}}],"Outlets":[{"uuid":"f1c71046-b754-49a5-8e66-d01374773dfc","ObjectName":"Outlet","id":1,"Hidden":false,"Custom":"Texture Out","Exposed":"texture out"}]},{"uuid":"e96c5c0b-7e09-49fb-a851-ff6f4811bb00","ObjectName":"gfxProcess","id":186,"Metadata":{"ScriptingName":"dome grid","Comment":"","Color":"White","Label":"","Touched":true},"Duration":12400285870,"Height":300.0,"StartO