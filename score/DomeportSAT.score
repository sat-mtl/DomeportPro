lue;\n  }\n}\n","Inlets":[{"uuid":"769dd38a-bfb3-4dc6-b52a-b6abb7afe2a3","ObjectName":"Inlet","id":0,"Hidden":false},{"uuid":"10d62b0d-5bc9-4ac9-9540-9e8ac0c24947","ObjectName":"Inlet","id":1,"Hidden":true,"Custom":"Filtered value","Exposed":"filtered value","Value":{"Float":0.0},"Init":{"Float":0.0},"Domain":{"Float":{"Min":0.0,"Max":1.0}}}],"Outlets":[{"uuid":"cff96158-cc72-46d7-99dc-b6038171375b","ObjectName":"Outlet","id":0,"Hidden":false}]},{"uuid":"846a5de5-47f9-46c5-a898-013cb20951d0","ObjectName":"Javascript","id":199,"Metadata":{"ScriptingName":"single-value_repetition_filter.10","Comment":"","Color":"White","Label":"","Touched":true},"Duration":12400285870,"Height":300.0,"StartOffset":0,"LoopDuration":12400285870,"Pos":[-1507.3075996844882,-796.3861033441872],"Size":[206.984375,22.0],"Loops":false,"Script":"import Score 1.0\nScript {\n  ValueInlet { id: in1 }\n  ValueOutlet { id: out1 }\n  FloatSpinBox { \n    id: filtered_value\n    objectName: \"Filtered value\"\n    init: 0\n  }\n\n  property real prev_input: 0.0\n  \n  tick: function(token, state) {\n    \n    if (in1.value != filtered_value.value) {\n      out1.value = in1.value;\n    }    \n    else {\n      if (prev_input == filtered_value.value) {\n        // do nothing\n      }\n      else {\n        // It is a new zero -> Keep it\n        out1.value = in1.value; \n      }\n    }\n    if (in1.value != undefined) prev_input = in1.value;\n  }\n}\n","Inlets":[{"uuid":"769dd38a-bfb3-4dc6-b52a-b6abb7afe2a3","ObjectName":"Inlet","id":0,"Hidden":false},{"uuid":"10d62b0d-5bc9-4ac9-9540-9e8ac0c24947","ObjectName":"Inlet","id":1,"Hidden":true,"Custom":"Filtered value","Exposed":"filtered value","Value":{"Float":0.0},"Init":{"Float":0.0},"Domain":{"Float":{"Min":0.0,"Max":1.0}}}],"Outlets":[{"uuid":"cff96158-cc72-46d7-99dc-b6038171375b","ObjectName":"Outlet","id":0,"Hidden":false}]},{"uuid":"846a5de5-47f9-46c5-a898-013cb20951d0","ObjectName":"Javascript","id":198,"Metadata":{"ScriptingName":"single-value_rep